{
  "url": "https://astaxis.vercel.app/",
  "viewport": { "width": 1920, "height": 1080 },
  "hideText": [
    "Concept demo by Jack Bikar — not an official site.",
    "Concept demo by Jack Bikar - not an official site."
  ],

  "recording": {
    "mode": "local",
    "connectUrl": "http://127.0.0.1:9222",
    "headful": false,
    "userDataDir": null,
    "chromePath": null,
    "stepPauseMs": 0
  },

  "meta": {
    "playbackSpeed": 1,
    "captions": false,
    "zoom": false,
    "preserveStart": false,
    "trimTailMs": 1500,
    "loadingOverlay": true,
    "loadingOverlaySeconds": 2.7,
    "topCropPx": 0
  },

  "steps": [
    {
      "type": "navigate",
      "target": "https://astaxis.vercel.app/",
      "waitUntil": "networkidle2",
      "silent": true,
      "why": "Load the homepage"
    },
    {
      "type": "wait",
      "ms": 300,
      "why": "Hold on the hero"
    },
    {
      "type": "scroll",
      "deltaY": 5400,
      "ms": 7700,
      "linear": true,
      "why": "One continuous scroll through the entire site at a steady pace"
    },
    {
      "type": "click",
      "target": "header a[href=\"/book\"]",
      "why": "Click the red Book Now button in the header"
    },
    {
      "type": "wait",
      "ms": 1200,
      "why": "Booking page loads"
    },
    {
      "type": "scroll",
      "deltaY": 620,
      "ms": 1000,
      "linear": true,
      "why": "Scroll down the booking form"
    },
    {
      "type": "wait",
      "ms": 800,
      "why": "Hold the booking form"
    }
  ]
}
