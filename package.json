{
  "name": "website-demo-videos",
  "private": true,
  "scripts": {
    "record": "node scripts/record.js",
    "record:local": "DEMO_LOCAL=1 node scripts/record.js",
    "record:connect": "DEMO_CONNECT_URL=${DEMO_CONNECT_URL:-http://127.0.0.1:9222} node scripts/record.js",
    "demo:local": "DEMO_LOCAL=1 node scripts/record.js && npm run trim && npm run keyframes && npm run render",
    "smooth": "node scripts/smooth.js",
    "trim": "node scripts/trim.js",
    "keyframes": "node scripts/keyframes.js",
    "render": "remotion render remotion/index.ts DemoVideo output/demo.mp4",
    "studio": "remotion studio remotion/index.ts",
    "demo": "npm run record && npm run trim && npm run keyframes && npm run render"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.469",
    "@remotion/renderer": "^4.0.469",
    "puppeteer-core": "^25.1.0",
    "remotion": "^4.0.469",
    "steel-sdk": "^0.18.0"
  }
}
